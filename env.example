# ── Brevo ───────────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ── Sender (must be a verified address in your Brevo account) ───────────────
SENDER_ADDRESS=your_verified_email@example.com
SENDER_NAME=Your Name

# ── Resume file path (relative to app.py, or absolute) ─────────────────────
RESUME_FILE=Hrithik_Raj_Resume.pdf

# ── Optional: protect /send and /status with a secret key ──────────────────
# API_KEY=some_secret_here

# ── Set to false to disable automatic sending on startup ───────────────────
AUTO_SEND=true

